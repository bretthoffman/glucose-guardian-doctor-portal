# Copy to .env.local for local development. Do NOT commit .env.local.
#
# Doctor auth is the backend's own email + password (hashed) -> Bearer token system,
# so no Clerk or Convex keys are needed by the portal.

# --- Glucose Guardian API ---
# Production: the portal calls this origin directly. Required for production builds.
VITE_API_BASE_URL=https://glucose-guardian-ashen.vercel.app

# Local dev only: leave VITE_API_BASE_URL UNSET in .env.local and set this instead, so the
# Vite dev server proxies /api/* to the live backend (avoids CORS while developing).
# VITE_API_PROXY_TARGET=https://glucose-guardian-ashen.vercel.app
